# Copy to .env.local for local dev. On Vercel, add these in Project → Settings → Environment Variables.

# Twilio: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Your Twilio phone number (E.164), e.g. +15551234567 — must be SMS-capable.
TWILIO_FROM_NUMBER=

# Your personal cell to receive new lead texts (E.164), e.g. +15559876543
TRAINER_NOTIFY_PHONE=
